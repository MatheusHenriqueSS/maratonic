model Image {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  bytes     Bytes
  createdAt DateTime @default(now())
}

type ProblemsStatus {
  solved Int @default(0)
  tried  Int @default(0)
}

enum UserRole {
  TEACHER
  STUDENT
}

enum PostType {
  POST
  SOLUTION
}
