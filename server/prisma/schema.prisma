datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Post {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  title         String
  content       String
  type          PostType   @default(POST)
  author        User       @relation(fields: [authorId], references: [id])
  authorId      String     @db.ObjectId
  categories    Category[] @relation(fields: [categoriesIDs], references: [id])
  categoriesIDs String[]   @db.ObjectId
}

model User {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  email    String   @unique
  nickname String
  role     UserRole @default(STUDENT)
  profile  Profile?
  posts    Post[]
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  posts       Post[]    @relation(fields: [postsIDs], references: [id])
  postsIDs    String[]  @db.ObjectId
  problems    Problem[] @relation(fields: [problemsIDs], references: [id])
  problemsIDs String[]  @db.ObjectId
}

model Problem {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  link          String
  categories    Category[] @relation(fields: [categoriesIDs], references: [id])
  categoriesIDs String[]   @db.ObjectId
}

model Profile {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  bio           String?
  problemStatus ProblemsStatus
  user          User           @relation(fields: [userId], references: [id])
  userId        String         @unique @db.ObjectId
}

model Image {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  bytes     Bytes
  createdAt DateTime @default(now())
}

type ProblemsStatus {
  solved Int @default(0)
  tried  Int @default(0)
}

enum UserRole {
  TEACHER
  STUDENT
}

enum PostType {
  POST
  SOLUTION
}
